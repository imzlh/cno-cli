{
  "name": "cno-cli",
  "version": "1.0.0",
  "description": "Deno-compatible TypeScript runtime CLI on circu.js (cno binary)",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "type-check": "tsc --noEmit",
    "bundle": "node scripts/bundle.mjs release",
    "bundle:min": "node scripts/bundle.mjs min",
    "configure": "cmake -B build -DCMAKE_BUILD_TYPE=Release .",
    "build": "cmake -B build",
    "dev": "cts src/main.ts"
  },
  "keywords": [
    "deno",
    "cno",
    "circu",
    "quickjs",
    "typescript",
    "runtime"
  ],
  "author": "iz",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "node-buffer": "npm:buffer@^6.0.3",
    "ts-interface-checker": "^1.0.2",
    "@cnojs/http": "workspace:./http"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
